# ── StaffOne Backend Environment Variables ──────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the .env file — only this .env.example.

# ── Environment ─────────────────────────────────────────────────────
ENVIRONMENT=development
# Set to "production" for production deployment

# ── Database ────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./staffone.db
# For PostgreSQL: postgresql://user:password@host:5432/dbname?sslmode=require
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20

# ── JWT Secrets ─────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_32_CHAR_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# For production: CORS_ORIGINS=https://your-frontend-domain.com

# ── SMTP (Email) ────────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_EMAIL=your-email@gmail.com
# SMTP_TLS=True

# ── Rate Limiting ───────────────────────────────────────────────────
# RATE_LIMIT_LOGIN=5/minute
# RATE_LIMIT_OTP=3/minute
